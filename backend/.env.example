# ── MongoDB (free at cloud.mongodb.com) ─────────────────────────────────────
# Also works with local: mongodb://localhost:27017
DATABASE_NAME=researchai
GROQ_API_KEY=Your_api_key
MONGO_URI=mongodb://localhost:27017
JWT_SECRET=supersecret
JWT_ALGORITHM=HS256
TAVILY_API_KEY=Your_api_key
# ── JWT ──────────────
# ── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=secretKey
# ── Groq (free at console.groq.com) ─────────────────────────────────────────

# ── Gmail SMTP (optional — leave blank to skip email) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your email ID
SMTP_PASSWORD=password for SMTP
EMAIL_FROM=ResearchAI <your email ID>


# ── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
